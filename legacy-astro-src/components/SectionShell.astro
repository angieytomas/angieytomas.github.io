---
interface Props {
  id: string;
  title: string;
  intro: string;
}

const { id, title, intro } = Astro.props;
---

<section id={id} class="section-anchor px-4 py-8 sm:px-6 sm:py-10">
  <div class="mx-auto max-w-6xl">
    <div class="mb-7 max-w-2xl">
      <h2 class="font-display text-4xl text-ink sm:text-5xl">{title}</h2>
      <p class="mt-3 text-base leading-8 text-ink/72">{intro}</p>
    </div>
    <slot />
  </div>
</section>
