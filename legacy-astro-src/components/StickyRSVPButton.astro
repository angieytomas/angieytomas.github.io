---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div class="fixed inset-x-0 bottom-0 z-50 p-4 md:hidden">
  <a
    href="#rsvp"
    class="mx-auto flex max-w-md items-center justify-center rounded-full bg-ink px-6 py-4 text-sm font-semibold text-white shadow-soft"
  >
    {label}
  </a>
</div>
