---
interface Item {
  time: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  items: Item[];
}

const { title, items } = Astro.props;
---

<div class="glass-card rounded-[1.75rem] p-6 sm:p-8">
  <h3 class="font-display text-3xl text-ink">{title}</h3>
  <div class="mt-6 space-y-5">
    {
      items.map((item) => (
        <div class="grid gap-3 border-t border-ink/10 pt-5 sm:grid-cols-[110px_1fr] sm:gap-6">
          <div class="text-sm font-semibold uppercase tracking-[0.24em] text-terracotta">{item.time}</div>
          <div>
            <h4 class="text-lg font-semibold text-ink">{item.title}</h4>
            <p class="mt-1 text-sm leading-7 text-ink/75">{item.description}</p>
          </div>
        </div>
      ))
    }
  </div>
</div>
